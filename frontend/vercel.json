{
  "rewrites": [
    {
      "source": "/health",
      "destination": "http://carrercompass.ap-southeast-2.elasticbeanstalk.com/health"
    },
    {
      "source": "/api/:path*",
      "destination": "http://carrercompass.ap-southeast-2.elasticbeanstalk.com/api/:path*"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
